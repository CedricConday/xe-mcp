# xe-mcp environment variables
# Copy to .env and fill in values (or set in shell / Claude Code MCP config)

# Xe Currency Data API credentials (optional)
# Without these, xe-mcp falls back to Frankfurter/ECB (free, no signup)
# Get credentials at: https://www.xe.com/xecurrencydata/
XE_ACCOUNT_ID=your_account_id_here
XE_API_KEY=your_api_key_here

# AWS (only needed for Lambda / SAM deployment)
# See template.yml and .github/workflows/deploy.yml
# AWS_REGION=ap-southeast-2
# ALERTS_TABLE=xe-mcp-alerts
# ALERT_QUEUE_URL=https://sqs.ap-southeast-2.amazonaws.com/123456789/xe-mcp-alerts
# CACHE_BUCKET=xe-mcp-rate-cache-123456789
