{
  "name": "xe-mcp",
  "version": "0.1.0",
  "description": "MCP server for the Xe Currency Data API — real-time rates, historical data, and volatility analysis in Claude Code",
  "main": "dist/index.js",
  "bin": {
    "xe-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "keywords": [
    "mcp",
    "xe",
    "currency",
    "fx",
    "exchange-rate",
    "claude",
    "claude-code"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    ".env.example",
    ".claude"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CedricConday/xe-mcp.git"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1075.0",
    "@aws-sdk/client-ses": "^3.1075.0",
    "@aws-sdk/client-sqs": "^3.1075.0",
    "@aws-sdk/util-dynamodb": "^3.996.5",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
